FROM rust:1.70.0

RUN \
mkdir -p /_tento && \
rustup default stable && \
rustup component add \
    clippy \
    rustfmt \
    rust-src && \
rustup target add \
    aarch64-apple-ios \
    aarch64-apple-ios-sim \
    aarch64-linux-android \
    x86_64-linux-android && \
apt-get update && \
apt-get install -y \
    cron \
    pkg-config \
    libssl-dev \
    valgrind && \
cargo install cargo-valgrind && \
cargo install diesel_cli --no-default-features --features postgres

# TODO TODO TODO для чего pkg-config, libssl-dev? МОжно ли без них?