{
    "dockerComposeFile": "./../../rust_language/docker/docker-compose.yaml",
    "service": "rust_language",
    "workspaceFolder": "/_tento",
    "extensions": [
		"rust-lang.rust-analyzer",
		"ms-azuretools.vscode-docker",
		"bungcip.better-toml",
		"irongeek.vscode-env",
		"ue.alphabetical-sorter"
    ],
    "settings": { 
		"terminal.integrated.shell.linux": "/bin/bash",
		"files.watcherExclude": {
			"**/target/**": true
		},
		"rust-analyzer.linkedProjects": [
			"/_tento/project/application/Cargo.toml"
		]

	}
}