// The file is for VSCode "ms-vscode-remote.vscode-remote-extensionpack" extension.
{
    "dockerComposeFile": "./docker-compose.yaml",
    "service": "rust",
    "workspaceFolder": "/usr/local/memis/",
    "extensions": [
		"matklad.rust-analyzer",
		"ms-azuretools.vscode-docker",
		"bungcip.better-toml",
		"irongeek.vscode-env",
		"ue.alphabetical-sorter"
    ],
    "settings": { 
		"terminal.integrated.shell.linux": "/bin/bash",
		"files.watcherExclude": {
			"**/target/**": true
		}
	}
}